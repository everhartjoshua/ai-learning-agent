# ─────────────────────────────────────────
# AI Learning Agent — environment template
# ─────────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.
# In GCP, these will move to Secret Manager — we'll wire that up in Phase 3.

# ── LLM provider ──────────────────────────────────────────────
# Choose one: ollama (local/free), groq (free tier), openai (paid)
LLM_PROVIDER=groq

# Ollama (local) — only used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Groq — free tier, fast, recommended for cloud deployment
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI — paid, used when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────
# Local default is SQLite. In GCP we'll swap to Cloud SQL Postgres in Phase 2.
# Example Postgres URL:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/learning_agent
DATABASE_URL=sqlite:///./data/student_data/learning_agent.db

# ── Vector store ──────────────────────────────────────────────
CHROMA_PATH=./data/materials/chroma_db

# ── Service discovery ────────────────────────────────────────
# Where the Streamlit frontend should look for the FastAPI backend.
# - Native dev (both processes on your host): leave as localhost
# - Docker Compose: http://backend:8000 (the compose service name)
# - Cloud Run: the deployed backend service URL (e.g. https://...run.app)
API_BASE=http://localhost:8000
